NODE_ENV=development
PORT=5050
MONGO_URI=mongodb://127.0.0.1:27017/gifta

JWT_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_strong_secret

REQUEST_EXPIRE_HOURS=72
MAX_ACTIVE_GIFT_ITEMS=5
MAX_ACTIVE_EXCHANGE_ITEMS=5
GIFT_LIMIT_PER_WEEK=2

# Local CDN-backed media storage
CDN_ROOT=/var/www/cdn.gifta.ge
CDN_BASE_URL=https://cdn.gifta.ge
MEDIA_MAX_UPLOAD_BYTES=10485760
MEDIA_ALLOWED_FOLDERS=items,avatars,blogs,temp,about,categories

# Optional rate-limit tuning
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000
